    <path d="M9 11a16 16 0 0 1 8-8c2 0 3 1 3 3a16 16 0 0 1-8 8z" />
    <path d="M9 11l-3-.5c-.4-.1-.5-.6-.2-.9l2.3-2.3c.3-.3.8-.4 1.2-.3l2 .5" />
    <path d="M13 15l.5 3c.1.4.6.5.9.2l2.3-2.3c.3-.3.4-.8.3-1.2l-.5-2" />
    <circle cx="14.5" cy="9.5" r="1.4" />
  </svg>
)}

{name === 'smart_toy' && (

    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
    <polyline points="7 10 12 15 17 10" />
    <line x1="12" y1="15" x2="12" y2="3" />
  </svg>
)}

{name === 'arrow_downward' && (
  <svg {...common} class={className}>
    <line x1="12" y1="5" x2="12" y2="19" />
    <polyline points="19 12 12 19 5 12" />
  </svg>
)}

{name === 'architecture' && (
  <svg {...common} class={className}>
    <path d="M12 3v7" />
    <path d="M12 10l-6 11" />
    <path d="M12 10l6 11" />
    <path d="M7.5 18.5h9" />
    <circle cx="12" cy="10" r="1.6" />
  </svg>
)}

{name === 'smartphone' && (
  <svg {...common} class={className}>
    <rect x="6" y="2" width="12" height="20" rx="2.5" ry="2.5" />
    <line x1="10" y1="18.5" x2="14" y2="18.5" />
  </svg>
)}

{name === 'verified' && (
  <svg {...common} class={className}>
    <path d="M12 2l2.4 1.8 3 .1.9 2.9 2.4 1.8-.9 2.9.9 2.9-2.4 1.8-.9 2.9-3 .1L12 22l-2.4-1.8-3-.1-.9-2.9L3.3 15.4l.9-2.9-.9-2.9 2.4-1.8.9-2.9 3-.1z" />
    <polyline points="9 12 11 14 15 10" />

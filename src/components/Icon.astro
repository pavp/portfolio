---
/**
 * Inline SVG icon set matching the Material Symbols glyphs used in the Stitch
 * design — with NO web-font dependency. Icons inherit color via `currentColor`
 * so they pick up var(--accent) etc. from the surrounding element.
 *
 * Glyphs: language, dark_mode, light_mode, download, arrow_downward,
 *         architecture, smartphone, verified, rocket_launch, smart_toy.
 */
interface Props {
  name:
    | 'language'
    | 'dark_mode'
    | 'light_mode'
    | 'download'
    | 'arrow_downward'
    | 'architecture'
    | 'smartphone'
    | 'verified'
    | 'rocket_launch'
    | 'smart_toy'
    | 'github'
    | 'linkedin'
    | 'mail';
  size?: number;
  class?: string;
  'aria-hidden'?: boolean;
}

const { name, size = 24, class: className = '', 'aria-hidden': ariaHidden = true } = Astro.props;

// Shared SVG attributes — stroke-based, inherits currentColor.
const common = {
  xmlns: 'http://www.w3.org/2000/svg',
  width: size,
  height: size,
  viewBox: '0 0 24 24',
  fill: 'none',
  stroke: 'currentColor',
  'stroke-width': 1.75,
  'stroke-linecap': 'round' as const,
  'stroke-linejoin': 'round' as const,
  'aria-hidden': ariaHidden,
  focusable: 'false',
};
---

{name === 'language' && (
  <svg {...common} class={className}>
    <circle cx="12" cy="12" r="9" />
    <line x1="3" y1="12" x2="21" y2="12" />
    <path d="M12 3a14 14 0 0 1 0 18a14 14 0 0 1 0-18" />
  </svg>
)}

{name === 'dark_mode' && (
  <svg {...common} class={className}>
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
  </svg>
)}

{name === 'light_mode' && (
  <svg {...common} class={className}>
    <circle cx="12" cy="12" r="5" />
    <line x1="12" y1="1" x2="12" y2="3" />
    <line x1="12" y1="21" x2="12" y2="23" />
    <line x1="4.22" y1="4.22" x2="5.64" y2="5.64" />
    <line x1="18.36" y1="18.36" x2="19.78" y2="19.78" />
    <line x1="1" y1="12" x2="3" y2="12" />
    <line x1="21" y1="12" x2="23" y2="12" />
    <line x1="4.22" y1="19.78" x2="5.64" y2="18.36" />
    <line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
  </svg>
)}

{name === 'download' && (

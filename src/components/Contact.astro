---
import type { ContactStrings } from '../i18n/types';
import Section from './Section.astro';
import SectionReveal from './SectionReveal.astro';
import Icon from './Icon.astro';

interface Props {
  contact: ContactStrings;
}

const { contact } = Astro.props;
---

<Section id="contact" heading={contact.heading}>
  <SectionReveal index={1}>
    <div class="contact-wrap">
      <!-- Availability statement (the seller) -->
      <p class="contact-statement">{contact.availability}</p>

      <!-- Primary CTA -->
      <a href={`mailto:${contact.email}`} class="contact-cta">
        {contact.ctaLabel}
        <Icon name="mail" size={18} />
      </a>

      <!-- Channels: Email (copy) · LinkedIn · GitHub -->
      <div class="contact-channels">
        <!-- Email with copy -->
        <button
          id="copy-email-btn"
          type="button"
          data-email={contact.email}
          data-copied-label={contact.copiedLabel}
          data-copy-label={contact.copyEmailLabel}
          class="contact-card"
          aria-label={contact.copyEmailLabel}
        >
          <span class="contact-card-icon"><Icon name="mail" size={20} /></span>
          <span class="contact-card-body">
            <span class="contact-card-label" id="copy-email-label">{contact.emailLabel}</span>
            <span class="contact-card-value">{contact.email}</span>
          </span>
        </button>

        <!-- LinkedIn -->
        <a
          href={contact.linkedinUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="contact-card"
          aria-label={`${contact.linkedinLabel} — ${contact.opensInNewTab}`}
        >
          <span class="contact-card-icon"><Icon name="linkedin" size={20} /></span>
          <span class="contact-card-body">
            <span class="contact-card-label">{contact.linkedinLabel}</span>
            <span class="contact-card-value">{contact.linkedinHandle}</span>
          </span>
        </a>

        <!-- GitHub -->
        <a
          href={contact.githubUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="contact-card"
          aria-label={`${contact.githubLabel} — ${contact.opensInNewTab}`}
        >
          <span class="contact-card-icon"><Icon name="github" size={20} /></span>
          <span class="contact-card-body">
            <span class="contact-card-label">{contact.githubLabel}</span>
            <span class="contact-card-value">{contact.githubHandle}</span>
          </span>
        </a>
      </div>
    </div>
  </SectionReveal>
</Section>

<style>
  .contact-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 2rem;
    max-width: 720px;
    margin: 0 auto;
  }

  .contact-statement {
    font-family: 'Manrope', system-ui, sans-serif;
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    line-height: 1.35;
    letter-spacing: -0.01em;
    color: var(--text);
    margin: 0;
  }

  .contact-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--accent);
    color: var(--on-accent);
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.01em;
    padding: 0.75rem 1.75rem;
    border-radius: 4px;
    text-decoration: none;
    transition: background-color 0.2s;
  }

  .contact-cta:hover {
    background: var(--accent-hover);
  }

  .contact-channels {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    width: 100%;
    margin-top: 0.5rem;
  }

  @media (min-width: 640px) {
    .contact-channels {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .contact-card {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 1.25rem;
    background: var(--surface);
    border: 1px solid var(--card-border);
    border-radius: 8px;
    text-decoration: none;
    text-align: left;
    cursor: pointer;
    width: 100%;
    font: inherit;
    transition: border-color 0.2s, background-color 0.2s;
  }

  .contact-card:hover {
    border-color: var(--accent);
  }

  .contact-card-icon {
    color: var(--accent);
    flex-shrink: 0;
    display: inline-flex;
  }

  .contact-card-body {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .contact-card-label {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 0.875rem;
    font-weight: 500;
    line-height: 1.2;
    letter-spacing: 0.01em;
    color: var(--text);
    margin-bottom: 0.125rem;
  }

  .contact-card-value {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 0.875rem;
    font-weight: 500;
    line-height: 1.2;
    letter-spacing: 0.01em;
    color: var(--text-secondary);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
</style>

<script>
  const btn = document.getElementById('copy-email-btn') as HTMLButtonElement | null;
  if (btn) {
    const label = document.getElementById('copy-email-label');
    const email = btn.dataset.email ?? '';
    const copiedLabel = btn.dataset.copiedLabel ?? 'Copied!';
    const copyLabel = btn.dataset.copyLabel ?? 'Email me';
    let timeout: ReturnType<typeof setTimeout>;

    btn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(email);
      } catch {
        // Clipboard API unavailable — still flash the confirmation.
      }
      if (label) label.textContent = copiedLabel;
      btn.setAttribute('aria-label', copiedLabel);
      clearTimeout(timeout);
      timeout = setTimeout(() => {
        if (label) label.textContent = copyLabel;
        btn.setAttribute('aria-label', copyLabel);
      }, 1500);
    });
  }
</script>

---
interface Props {
  id: string;
  heading?: string;
  class?: string;
}

const { id, heading, class: className = '' } = Astro.props;
---

<section
  id={id}
  aria-label={heading}
  class:list={['py-section', className]}
  style="padding-top: 80px; padding-bottom: 80px;"
>
  <div>
    {heading && (
      <h2
        style="font-family: 'Manrope', system-ui, sans-serif; font-size: 2rem; font-weight: 700; letter-spacing: -0.01em; line-height: 1.3; color: var(--text); margin-bottom: 2.5rem; display: inline-block; border-bottom: 1px solid var(--card-border); padding-bottom: 1rem;"
      >
        {heading}
      </h2>
    )}
    <slot />
  </div>
</section>

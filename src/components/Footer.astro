---
import type { FooterStrings } from '../i18n/types';

interface Props {
  footer: FooterStrings;
}

const { footer } = Astro.props;
const year = new Date().getFullYear();
---

<footer
  role="contentinfo"
  style="border-top: 1px solid var(--card-border); padding: 3rem 1.5rem; margin-top: 5rem;"
>
  <div style="max-width: 1200px; margin: 0 auto; display: flex; flex-direction: column; gap: 1.5rem;">
    <!-- Top row: name + tech stack -->
    <div class="footer-top">
      <div style="display: flex; flex-direction: column; gap: 0.25rem;">
        <span
          style="font-family: 'Manrope', system-ui, sans-serif; font-size: 1.5rem; font-weight: 600; line-height: 1.4; color: var(--text);"
        >
          Pedro Villarreal
        </span>
        <span style="font-family: 'Inter', system-ui, sans-serif; font-size: 0.875rem; font-weight: 500; letter-spacing: 0.01em; color: var(--text-secondary);">
          {footer.tagline}
        </span>
      </div>
      <div class="footer-tech" style="display: flex; flex-direction: column; gap: 0.25rem;">
        <span style="font-family: 'Inter', system-ui, sans-serif; font-size: 0.75rem; font-weight: 600; line-height: 1.2; letter-spacing: 0.05em; color: var(--accent);">React Native • React • Next.js</span>
        <span style="font-family: 'Inter', system-ui, sans-serif; font-size: 0.75rem; font-weight: 600; line-height: 1.2; letter-spacing: 0.05em; color: var(--text-variant);">Frontend Architecture • CI/CD • Design Systems</span>
        <span style="font-family: 'Inter', system-ui, sans-serif; font-size: 0.75rem; font-weight: 600; line-height: 1.2; letter-spacing: 0.05em; color: var(--text-secondary); margin-top: 0.25rem;">Madrid, Spain | Open to Remote Opportunities</span>
      </div>
    </div>

    <!-- Bottom row: copyright + links -->
    <div class="footer-bottom" style="border-top: 1px solid var(--card-border); padding-top: 1.5rem;">
      <p style="font-family: 'Inter', system-ui, sans-serif; font-size: 0.75rem; font-weight: 600; line-height: 1.2; letter-spacing: 0.05em; color: var(--outline-variant); margin: 0;">
        &copy; {year} {footer.copyright}
      </p>
      <div style="display: flex; gap: 1.5rem;">
        <a href="https://linkedin.com/in/villapp" target="_blank" rel="noopener noreferrer" class="footer-link" style="font-family: 'Inter', system-ui, sans-serif; font-size: 0.875rem; font-weight: 500; letter-spacing: 0.01em; color: var(--text-variant); text-decoration: none; transition: color 0.2s;">LinkedIn</a>
        <a href="mailto:pedrovillarreal@gmail.com" class="footer-link" style="font-family: 'Inter', system-ui, sans-serif; font-size: 0.875rem; font-weight: 500; letter-spacing: 0.01em; color: var(--text-variant); text-decoration: none; transition: color 0.2s;">Email</a>
        <a href="/pedro-villarreal-cv.pdf" download="pedro-villarreal-cv.pdf" class="footer-link" style="font-family: 'Inter', system-ui, sans-serif; font-size: 0.875rem; font-weight: 500; letter-spacing: 0.01em; color: var(--text-variant); text-decoration: none; transition: color 0.2s;">Resume</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer-link:hover {
    color: var(--accent);
  }

  .footer-top {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    text-align: center;
    align-items: center;
  }

  .footer-tech {
    text-align: center;
    align-items: center;
  }

  .footer-bottom {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: center;
    text-align: center;
  }

  @media (min-width: 768px) {
    .footer-top {
      flex-direction: row;
      justify-content: space-between;
      align-items: flex-start;
      text-align: left;
    }

    .footer-tech {
      text-align: right;
      align-items: flex-end;
    }

    .footer-bottom {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
      text-align: left;
    }
  }
</style>

---
import type { FooterStrings } from '../i18n/types';

interface Props {
  footer: FooterStrings;
}

const { footer } = Astro.props;
const year = new Date().getFullYear();
---

<footer
  role="contentinfo"
  style="border-top: 1px solid var(--card-border); padding: 2rem 1.5rem; text-align: center;"
>
  <div style="max-width: 1200px; margin: 0 auto;">
    <p
      style="font-family: 'Manrope', system-ui, sans-serif; font-weight: 700; color: var(--text); margin: 0 0 0.375rem; font-size: 0.9375rem;"
    >
      Pedro Villarreal
    </p>
    <p style="color: var(--text-secondary); font-size: 0.875rem; margin: 0 0 0.5rem;">
      {footer.tagline}
    </p>
    <p style="color: var(--text-secondary); font-size: 0.8125rem; margin: 0;">
      &copy; {year} {footer.copyright}
    </p>
  </div>
</footer>

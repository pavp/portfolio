---
import type { AboutStrings } from '../i18n/types';
import SectionReveal from './SectionReveal.astro';

interface Props {
  about: AboutStrings;
}

const { about } = Astro.props;
---

<section
  id="about"
  aria-label={about.heading}
  style="padding-top: 80px; padding-bottom: 80px;"
>
  <div>
    <div class="about-grid">
      <!-- Left: heading label -->
      <div class="about-label">
        <SectionReveal index={1}>
          <h2
            style="font-family: 'Manrope', system-ui, sans-serif; font-size: 2rem; font-weight: 700; letter-spacing: -0.01em; line-height: 1.3; color: var(--text); display: inline-block; border-bottom: 1px solid var(--card-border); padding-bottom: 1rem;"
          >
            {about.heading}
          </h2>
        </SectionReveal>
      </div>

      <!-- Right: content -->
      <div class="about-content">
        <SectionReveal index={2}>
          <div style="display: flex; flex-direction: column; gap: 1rem;">
            {about.body.map((paragraph) => (
              <p style="font-family: 'Inter', system-ui, sans-serif; font-size: 1.125rem; font-weight: 400; letter-spacing: normal; color: var(--text-secondary); line-height: 1.6; margin: 0;">
                {paragraph}
              </p>
            ))}

            <!-- Education card -->
            <div
              class="card"
              style="padding: 1.5rem; margin-top: 1rem;"
            >
              <h3
                style="font-family: 'Inter', system-ui, sans-serif; font-size: 0.75rem; font-weight: 600; line-height: 1.2; letter-spacing: 0.05em; color: var(--accent); text-transform: uppercase; margin: 0 0 1rem;"
              >
                {about.education.label}
              </h3>
              <div style="font-family: 'Manrope', system-ui, sans-serif; font-size: 1.5rem; font-weight: 600; line-height: 1.4; letter-spacing: normal; color: var(--text); margin-bottom: 0.25rem;">
                {about.education.degree}
              </div>
              <div style="font-family: 'Inter', system-ui, sans-serif; font-size: 1rem; font-weight: 400; line-height: 1.6; letter-spacing: normal; color: var(--text-secondary); margin-bottom: 0.25rem;">
                {about.education.institution}
              </div>
              <div style="font-family: 'Inter', system-ui, sans-serif; font-size: 0.875rem; font-weight: 500; line-height: 1.2; letter-spacing: 0.01em; color: var(--text-secondary);">
                {about.education.period}
              </div>
            </div>
          </div>
        </SectionReveal>
      </div>
    </div>
  </div>
</section>

<style>
  .about-grid {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  @media (min-width: 768px) {
    .about-grid {
      display: grid;
      grid-template-columns: 4fr 8fr;
      gap: 3rem;
      align-items: start;
    }
  }
</style>

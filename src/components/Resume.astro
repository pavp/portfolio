---
import type { ResumeStrings } from '../i18n/types';
import Section from './Section.astro';
import SectionReveal from './SectionReveal.astro';

interface Props {
  resume: ResumeStrings;
}

const { resume } = Astro.props;
---

<Section id="resume" heading={resume.heading}>
  <SectionReveal index={1}>
    <div
      class="card"
      style="padding: 2rem; border-radius: 12px; max-width: 560px; display: flex; flex-direction: column; gap: 1.5rem;"
    >
      <!-- Preview label -->
      <div style="display: flex; align-items: center; gap: 1rem;">
        <!-- Document icon -->
        <div
          style="width: 48px; height: 60px; background: color-mix(in srgb, var(--accent) 10%, transparent); border: 1px solid color-mix(in srgb, var(--accent) 30%, transparent); border-radius: 6px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;"
          aria-hidden="true"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--accent);">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14 2 14 8 20 8"/>
            <line x1="16" y1="13" x2="8" y2="13"/>
            <line x1="16" y1="17" x2="8" y2="17"/>
            <polyline points="10 9 9 9 8 9"/>
          </svg>
        </div>
        <div>
          <div
            style="font-family: 'Manrope', system-ui, sans-serif; font-weight: 700; color: var(--text); margin-bottom: 0.25rem;"
          >
            {resume.previewLabel}
          </div>
          <div style="font-size: 0.875rem; color: var(--text-secondary);">
            {resume.lastUpdatedLabel}: <time datetime="2026-06-14">{resume.lastUpdatedDate}</time>
          </div>
        </div>
      </div>

      <!-- Download button -->
      <a
        href="/pedro-villarreal-cv.pdf"
        download="pedro-villarreal-cv.pdf"
        style="display: inline-flex; align-items: center; gap: 0.5rem; background: var(--accent); color: #fff; font-weight: 600; font-size: 0.9375rem; padding: 0.625rem 1.25rem; border-radius: 4px; text-decoration: none; transition: opacity 0.2s; width: fit-content;"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
          <polyline points="7 10 12 15 17 10"/>
          <line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
        {resume.downloadLabel}
      </a>
    </div>
  </SectionReveal>
</Section>

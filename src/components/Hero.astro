---
import type { HeroStrings } from '../i18n/types';
import Icon from './Icon.astro';

interface Props {
  hero: HeroStrings;
}

const { hero } = Astro.props;
---

<section
  aria-label="Hero"
  style="min-height: 819px; display: flex; flex-direction: column; justify-content: center; padding-top: 36px; padding-bottom: 3rem;"
>
  <div style="max-width: 768px; width: 100%; display: flex; flex-direction: column; gap: 1.5rem; align-items: flex-start; text-align: left;">
    <!-- Headshot -->
    <img
      src="/headshot.jpg"
      alt="Pedro Villarreal — Senior Frontend Engineer"
      width="100"
      height="100"
      style="border-radius: 12px; object-fit: cover; flex-shrink: 0; display: block;"
      loading="eager"
    />

    <!-- Headline (display-lg) -->
    <h1
      style="font-family: 'Manrope', system-ui, sans-serif; font-size: clamp(2.25rem, 5vw, 3rem); font-weight: 800; letter-spacing: -0.02em; line-height: 1.1; color: var(--text); margin: 0; max-width: 46rem;"
    >
      {hero.headline}
    </h1>

    <!-- Subtitle (body-lg: 18px / 400 / Inter) -->
    <p
      style="font-family: 'Inter', system-ui, sans-serif; font-size: 1.125rem; font-weight: 400; color: var(--text-secondary); line-height: 1.6; max-width: 640px; margin: 0;"
    >
      {hero.subtitle}
    </p>

    <!-- Specialization overline (label-md: 14px / 500 / Inter, uppercase tracking-widest) -->
    <p
      style="font-family: 'Inter', system-ui, sans-serif; font-size: 0.875rem; font-weight: 500; letter-spacing: 0.1em; color: var(--accent); margin: 0; text-transform: uppercase;"
    >
      {hero.specialization}
    </p>

    <!-- CTA buttons -->
    <div style="display: flex; flex-wrap: wrap; gap: 1rem; margin-top: 0.5rem;">
      <a
        href="/pedro-villarreal-cv.pdf"
        download="pedro-villarreal-cv.pdf"
        class="hero-btn-filled"
        style="display: inline-flex; align-items: center; gap: 0.375rem; background: var(--accent); color: var(--on-accent); font-family: 'Inter', system-ui, sans-serif; font-size: 0.875rem; font-weight: 500; letter-spacing: 0.01em; padding: 0.625rem 1.5rem; border-radius: 4px; text-decoration: none; transition: background-color 0.2s; white-space: nowrap;"
      >
        {hero.downloadResume}
        <Icon name="download" size={18} />
      </a>
      <a
        href="#contact"
        class="hero-btn-outline"
        style="display: inline-flex; align-items: center; gap: 0.375rem; background: transparent; border: 1px solid var(--outline); color: var(--text); font-family: 'Inter', system-ui, sans-serif; font-size: 0.875rem; font-weight: 500; letter-spacing: 0.01em; padding: 0.625rem 1.5rem; border-radius: 4px; text-decoration: none; transition: border-color 0.2s, color 0.2s; white-space: nowrap;"
      >
        {hero.contactMe}
      </a>
      <a
        href="#experience"
        class="hero-btn-text"
        style="display: inline-flex; align-items: center; gap: 0.375rem; background: transparent; color: var(--text-secondary); font-family: 'Inter', system-ui, sans-serif; font-size: 0.875rem; font-weight: 500; letter-spacing: 0.01em; padding: 0.625rem 1.5rem; border-radius: 4px; text-decoration: none; transition: color 0.2s; white-space: nowrap;"
      >
        {hero.viewExperience}
        <Icon name="arrow_downward" size={18} class="hero-arrow" />
      </a>
    </div>

    <!-- Badges (pill shape rounded-full) -->
    <div style="display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 0.5rem;">
      {hero.badges.map((badge) => (
        <span
          style="font-family: 'Inter', system-ui, sans-serif; font-size: 0.75rem; font-weight: 600; line-height: 1.2; letter-spacing: 0.05em; color: var(--text-secondary); border: 1px solid var(--card-border); border-radius: 9999px; padding: 4px 16px;"
        >
          {badge}
        </span>
      ))}
    </div>
  </div>
</section>

<style>
  .hero-btn-filled:hover {
    background: var(--accent-hover);
  }
  .hero-btn-outline:hover {
    border-color: var(--accent);
    color: var(--accent);
  }
  .hero-btn-text:hover {
    color: var(--accent);
  }
  .hero-btn-text:hover :global(.hero-arrow) {
    transform: translateY(4px);
  }
  .hero-btn-text :global(.hero-arrow) {
    transition: transform 0.2s;
  }

  @media (max-width: 640px) {
    section > div {
      align-items: center;
      text-align: center;
    }
    section > div > div {
      justify-content: center;
    }
  }
</style>

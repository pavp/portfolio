---
import type { HeroStrings } from '../i18n/types';

interface Props {
  hero: HeroStrings;
}

const { hero } = Astro.props;
---

<section
  aria-label="Hero"
  style="min-height: 100vh; display: flex; flex-direction: column; justify-content: center; padding: 0 1.5rem; padding-top: 80px;"
>
  <div style="max-width: 1200px; margin: 0 auto; width: 100%;">
    <!-- Headshot + name row -->
    <div style="display: flex; align-items: center; gap: 1.5rem; margin-bottom: 2rem;">
      <!-- Headshot placeholder — TODO: replace with Pedro's real B&W photo -->
      <img
        src="/headshot.jpg"
        alt="Pedro Villarreal — Senior Frontend Engineer"
        width="80"
        height="80"
        style="border-radius: 50%; object-fit: cover; border: 2px solid var(--card-border); flex-shrink: 0;"
        loading="eager"
      />
      <div>
        <h1
          style="font-family: 'Manrope', system-ui, sans-serif; font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 800; letter-spacing: -0.03em; color: var(--text); margin: 0 0 0.25rem;"
        >
          Pedro Villarreal
        </h1>
        <div style="display: flex; gap: 0.75rem; flex-wrap: wrap; align-items: center;">
          <span
            style="font-size: 1.125rem; color: var(--text-secondary); font-weight: 500;"
          >
            {hero.title}
          </span>
          <span
            style="font-size: 0.8125rem; color: var(--text-secondary); background: var(--surface); border: 1px solid var(--card-border); border-radius: 4px; padding: 2px 8px;"
          >
            {hero.locationTag}
          </span>
          <span
            style="font-size: 0.8125rem; color: var(--accent); background: color-mix(in srgb, var(--accent) 10%, transparent); border: 1px solid color-mix(in srgb, var(--accent) 30%, transparent); border-radius: 4px; padding: 2px 8px; font-weight: 600;"
          >
            {hero.availabilityTag}
          </span>
        </div>
      </div>
    </div>

    <!-- Specialization line -->
    <p
      style="font-size: 0.75rem; font-weight: 700; letter-spacing: 0.12em; color: var(--accent); margin: 0 0 1.5rem; font-family: 'Manrope', system-ui, sans-serif;"
    >
      {hero.specialization}
    </p>

    <!-- Headline -->
    <h2
      style="font-family: 'Manrope', system-ui, sans-serif; font-size: clamp(1.375rem, 3vw, 2rem); font-weight: 700; letter-spacing: -0.02em; color: var(--text); line-height: 1.3; max-width: 760px; margin: 0 0 1rem;"
    >
      {hero.headline}
    </h2>

    <!-- Subtitle -->
    <p
      style="font-size: 1.0625rem; color: var(--text-secondary); line-height: 1.6; max-width: 640px; margin: 0 0 2rem;"
    >
      {hero.subtitle}
    </p>

    <!-- Badges -->
    <div style="display: flex; flex-wrap: wrap; gap: 0.5rem;">
      {hero.badges.map((badge) => (
        <span
          style="font-size: 0.8125rem; font-weight: 500; color: var(--text-secondary); background: var(--surface); border: 1px solid var(--card-border); border-radius: 4px; padding: 4px 12px;"
        >
          {badge}
        </span>
      ))}
    </div>
  </div>
</section>

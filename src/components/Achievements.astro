---
import type { AchievementsStrings } from '../i18n/types';
import SectionReveal from './SectionReveal.astro';

interface Props {
  achievements: AchievementsStrings;
}

const { achievements } = Astro.props;
---

<section
  id="achievements"
  aria-label={achievements.heading}
  style="padding-top: 80px; padding-bottom: 80px;"
>
  <div>
    <div class="ach-grid">
      <!-- Left: heading label -->
      <div class="ach-label">
        <SectionReveal index={1}>
          <h2
            style="font-family: 'Manrope', system-ui, sans-serif; font-size: 2rem; font-weight: 700; letter-spacing: -0.01em; line-height: 1.3; color: var(--text); display: inline-block; border-bottom: 1px solid var(--card-border); padding-bottom: 1rem;"
          >
            {achievements.heading}
          </h2>
        </SectionReveal>
      </div>

      <!-- Right: card grid -->
      <div class="ach-content">
        <SectionReveal index={2}>
          <div class="ach-cards">
            {achievements.items.map((item) => (
              <div
                style="padding: 1.5rem; border: 1px solid color-mix(in srgb, var(--outline-variant) 20%, transparent); border-radius: 8px; background: color-mix(in srgb, var(--surface) 50%, transparent);"
              >
                <h3
                  style="font-family: 'Inter', system-ui, sans-serif; font-size: 0.875rem; font-weight: 500; letter-spacing: 0.01em; color: var(--text); margin: 0 0 0.5rem; line-height: 1.2;"
                >
                  {item.title}
                </h3>
                <p style="font-family: 'Inter', system-ui, sans-serif; font-size: 0.875rem; font-weight: 400; letter-spacing: 0; color: var(--text-secondary); line-height: 1.4; margin: 0;">
                  {item.descriptor}
                </p>
              </div>
            ))}
          </div>
        </SectionReveal>
      </div>
    </div>
  </div>
</section>

<style>
  .ach-grid {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .ach-cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  @media (min-width: 640px) {
    .ach-cards {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 768px) {
    .ach-grid {
      display: grid;
      grid-template-columns: 4fr 8fr;
      gap: 3rem;
      align-items: start;
    }
    /* Force heading to wrap to 2 lines like Stitch */
    .ach-label h2 {
      max-width: 12ch;
    }
  }
</style>

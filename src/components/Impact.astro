---
import type { ImpactStrings } from '../i18n/types';
import SectionReveal from './SectionReveal.astro';

interface Props {
  impact: ImpactStrings;
}

const { impact } = Astro.props;
---

<section
  aria-label="Impact Metrics"
  style="border-top: 1px solid var(--card-border); border-bottom: 1px solid var(--card-border); padding: 3rem 0;"
>
  <div>
    <div class="impact-grid">
      {impact.metrics.map((metric, i) => (
        <SectionReveal index={i + 1}>
          <div class="impact-item">
            <div
              style="font-family: 'Manrope', system-ui, sans-serif; font-size: 2rem; font-weight: 700; color: var(--accent); letter-spacing: -0.01em; line-height: 1.3; margin-bottom: 0.25rem;"
            >
              {metric.value}
            </div>
            <div style="font-family: 'Inter', system-ui, sans-serif; font-size: 0.875rem; font-weight: 500; line-height: 1.2; letter-spacing: 0.01em; color: var(--text-secondary);">
              {metric.label}
            </div>
          </div>
        </SectionReveal>
      ))}
    </div>
  </div>
</section>

<style>
  .impact-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 1.5rem;
    text-align: center;
  }

  @media (min-width: 768px) {
    .impact-grid {
      grid-template-columns: repeat(5, 1fr);
      text-align: left;
    }
  }
</style>

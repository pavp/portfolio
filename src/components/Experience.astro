---
import type { ExperienceStrings } from '../i18n/types';
import type { Role } from '../data/experience';
import Section from './Section.astro';
import SectionReveal from './SectionReveal.astro';

interface Props {
  experience: ExperienceStrings;
  topRoles: Role[];
  earlierRoles: Role[];
}

const { experience, topRoles, earlierRoles } = Astro.props;

// Map company names to translation keys
const roleKeys = ['nextlane', 'capitole', 'makingSense', 'novacomp', 'urijiJami'] as const;
const earlierRoleKeys = ['fancision', 'threehundredDev', 'teravision'] as const;
---

<Section id="experience" heading={experience.heading}>
  <!-- 2px vertical timeline -->
  <div style="position: relative; padding-left: 2rem;">
    <div class="timeline-line"></div>

    <!-- Top 5 roles -->
    {topRoles.map((role, i) => {
      const key = roleKeys[i];
      const roleData = experience.roles[key];
      const isCurrent = role.current;

      return (
        <SectionReveal index={i + 1}>
          <div
            style={`position: relative; margin-bottom: 2.5rem; padding: 1.5rem; background: var(--surface); border: ${isCurrent ? '1px solid var(--accent)' : '1px solid var(--card-border)'}; border-radius: 8px;`}
          >
            <!-- Timeline dot -->
            <div class:list={['timeline-dot', isCurrent ? 'current' : '']} style="top: 1.75rem;"></div>

            <!-- Header row -->
            <div style="display: flex; align-items: flex-start; justify-content: space-between; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 1rem;">
              <div>
                <div style="display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap; margin-bottom: 0.25rem;">
                  <span
                    style={`font-family: 'Manrope', system-ui, sans-serif; font-size: 1.0625rem; font-weight: 700; color: ${isCurrent ? 'var(--accent)' : 'var(--text)'};`}
                  >
                    {role.company}
                  </span>
                  {isCurrent && (
                    <span
                      style="font-size: 0.6875rem; font-weight: 700; color: var(--accent); background: color-mix(in srgb, var(--accent) 10%, transparent); border: 1px solid color-mix(in srgb, var(--accent) 30%, transparent); border-radius: 4px; padding: 2px 6px; letter-spacing: 0.06em; text-transform: uppercase;"
                    >
                      {experience.currentBadge}
                    </span>
                  )}
                </div>
                <div style="color: var(--text-secondary); font-size: 0.9375rem; font-weight: 500;">
                  {roleData.title}
                </div>
              </div>
              <div style="text-align: right;">
                <div style="color: var(--text-secondary); font-size: 0.875rem;">{role.period}</div>
                <div style="color: var(--text-secondary); font-size: 0.8125rem;">{role.location}</div>
              </div>
            </div>

            <!-- Bullets -->
            <ul style="list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.375rem;">
              {roleData.bullets.map((bullet) => (
                <li
                  style="font-size: 0.9375rem; color: var(--text-secondary); line-height: 1.6; padding-left: 1rem; position: relative;"
                >
                  <span
                    style="position: absolute; left: 0; color: var(--accent);"
                    aria-hidden="true"
                  >›</span>
                  {bullet}
                </li>
              ))}
            </ul>
          </div>
        </SectionReveal>
      );
    })}

    <!-- Earlier roles accordion (zero JS — native <details>) -->
    <SectionReveal index={6}>
      <details style="margin-top: 0.5rem;">
        <summary
          style="cursor: pointer; font-family: 'Manrope', system-ui, sans-serif; font-size: 0.9375rem; font-weight: 600; color: var(--text-secondary); padding: 0.75rem 1rem; background: var(--surface); border: 1px solid var(--card-border); border-radius: 8px; list-style: none; display: flex; align-items: center; justify-content: space-between;"
        >
          <span>{experience.earlierRolesLabel}</span>
          <span aria-hidden="true" style="font-size: 1.25rem; line-height: 1;">›</span>
        </summary>

        <div style="padding-top: 1rem; display: flex; flex-direction: column; gap: 1.5rem;">
          {earlierRoles.map((role, i) => {
            const key = earlierRoleKeys[i];
            const roleData = experience.earlierRoles[key];
            return (
              <div
                style="padding: 1.25rem; background: var(--surface); border: 1px solid var(--card-border); border-radius: 8px; position: relative;"
              >
                <div class="timeline-dot" style="top: 1.5rem;"></div>
                <div style="display: flex; justify-content: space-between; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 0.75rem;">
                  <div>
                    <div style="font-family: 'Manrope', system-ui, sans-serif; font-size: 1rem; font-weight: 700; color: var(--text); margin-bottom: 0.125rem;">
                      {role.company}
                    </div>
                    <div style="color: var(--text-secondary); font-size: 0.875rem;">
                      {roleData.title}
                    </div>
                  </div>
                  <div style="text-align: right;">
                    <div style="color: var(--text-secondary); font-size: 0.875rem;">{role.period}</div>
                    <div style="color: var(--text-secondary); font-size: 0.8125rem;">{role.location}</div>
                  </div>
                </div>
                <ul style="list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.25rem;">
                  {roleData.bullets.map((bullet) => (
                    <li style="font-size: 0.875rem; color: var(--text-secondary); line-height: 1.6; padding-left: 1rem; position: relative;">
                      <span style="position: absolute; left: 0; color: var(--accent);" aria-hidden="true">›</span>
                      {bullet}
                    </li>
                  ))}
                </ul>
              </div>
            );
          })}
        </div>
      </details>
    </SectionReveal>
  </div>
</Section>
